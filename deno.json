{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": {
      "command": "deno fmt --check . && deno lint . && deno check",
      "dependencies": ["gen"]
    },
    "dev": {
      "command": "vite",
      "dependencies": ["gen:icons", "gen"]
    },
    "build": {
      "command": "vite build",
      "dependencies": ["gen:icons", "gen"]
    },
    "gen": "deno run -A scripts/gen_content.ts",
    "gen:icons": "deno run -A scripts/generate_icons.ts",
    "start": "deno task gen && deno serve -A _fresh/server.js",
    "test": {
      "command": "deno test -A",
      "dependencies": ["gen"]
    },
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "exclude": ["./lib/posts.generated.ts"],
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "fmt": {
    "exclude": ["./static", "./lib/posts.generated.ts"]
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@phosphor-icons/core": "npm:@phosphor-icons/core@^2.1.1",
    "@phosphor-icons/react": "npm:@phosphor-icons/react@^2.1.10",
    "@phosphor-icons/react/": "npm:@phosphor-icons/react@^2.1.10/",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "date-fns": "npm:date-fns@^4.4.0",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.2",
    "@preact/signals": "npm:@preact/signals@^2.9.2",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "satteri": "npm:satteri@^0.9.3",
    "shiki": "npm:shiki@^4.3.0",
    "swr": "npm:swr@^2.4.2",
    "vite": "npm:vite@^7.3.6",
    "tailwindcss": "npm:tailwindcss@^4.3.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.1"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "deploy": {
    "org": "hewel",
    "app": "pigmint"
  }
}
